# ─── Core ────────────────────────────────────────────────────────────────────
# JWT secret for admin authentication — REQUIRED in production
JWT_SECRET=change-me-to-a-long-random-string

# Admin account credentials (auto-seeded on first startup)
ADMIN_EMAIL=admin@starv3.com
ADMIN_PASSWORD=admin123

# ─── SQLite ──────────────────────────────────────────────────────────────────
# Writable directory for the SQLite database file.
# On Vercel/Lambda this MUST be /tmp (read-only filesystem except /tmp).
# Leave unset locally — defaults to ./data/
DATA_DIR=/tmp/galaxymart-data

# ─── Payments ────────────────────────────────────────────────────────────────
# NOWPayments API key — omit to run in mock mode (full checkout flow still works)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Your Litecoin wallet address for receiving payments
LTC_WALLET_ADDRESS=

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# SMTP credentials for order confirmation emails
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@starv3.com

# ─── Frontend (Vercel build-time env vars) ───────────────────────────────────
# If your API is hosted separately, set this to the full API base URL.
# Leave empty to use the same origin (/api → Vercel serverless function).
VITE_API_URL=

# ─── Server ──────────────────────────────────────────────────────────────────
# Set automatically by Vercel/Replit. Do not set manually in production.
PORT=8080
