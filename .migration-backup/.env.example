# ── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Admin Login ──────────────────────────────────────
ADMIN_EMAIL=admin@dragonzstore.com
ADMIN_PASSWORD=ChangeThisPassword!

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string

# ── NOWPayments (Litecoin) ───────────────────────────
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_ipn_secret
LTC_WALLET_ADDRESS=your_ltc_wallet_address

# ── Email delivery (Gmail) ───────────────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Public URL (used for payment webhooks) ───────────
BASE_URL=https://your-app.onrender.com

# ── Database (Render persistent disk) ───────────────
# Leave blank in development — db is stored in server/
# On Render this is set automatically via render.yaml
# DATA_DIR=/opt/render/project/src/data
