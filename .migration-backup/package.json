{
  "name": "dragonzstore",
  "version": "1.0.0",
  "description": "DragonzStore - Premium Digital Products Ecommerce",
  "main": "server/index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\" --names \"SERVER,CLIENT\" --prefix-colors \"yellow,cyan\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev -- --port 5000 --host 0.0.0.0",
    "build": "cd client && npm install && npm run build",
    "start": "NODE_ENV=production node server/index.js",
    "render-build": "npm install && npm run build"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "sqlite3": "^6.0.1",
    "uuid": "^14.0.0"
  }
}
